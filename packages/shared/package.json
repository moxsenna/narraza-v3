{
  "name": "@narraza/shared",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./env/web": {
      "types": "./dist/env/web.d.ts",
      "default": "./dist/env/web.js"
    },
    "./env/worker": {
      "types": "./dist/env/worker.d.ts",
      "default": "./dist/env/worker.js"
    },
    "./env/outbox": {
      "types": "./dist/env/outbox.d.ts",
      "default": "./dist/env/outbox.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsc -b",
    "test": "pnpm run test:unit",
    "test:unit": "vitest run --passWithNoTests",
    "clean": "rimraf dist *.tsbuildinfo"
  },
  "dependencies": {
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@types/node": "26.1.1",
    "vitest": "4.1.10"
  }
}
