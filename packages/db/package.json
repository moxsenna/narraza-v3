{
  "name": "@narraza/db",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "prisma generate && tsc -b",
    "pretest": "prisma generate",
    "test": "pnpm run test:integration",
    "pretest:integration": "prisma generate",
    "test:integration": "vitest run --passWithNoTests",
    "generate": "prisma generate",
    "migrate": "tsx src/migrate.ts",
    "migrate:dev": "prisma migrate dev",
    "migrate:deploy": "prisma migrate deploy",
    "clean": "rimraf dist *.tsbuildinfo"
  },
  "dependencies": {
    "@auth/prisma-adapter": "2.11.3",
    "@narraza/application": "workspace:*",
    "@narraza/core": "workspace:*",
    "@narraza/shared": "workspace:*",
    "@prisma/adapter-pg": "7.9.0",
    "@prisma/client": "7.9.0",
    "pg": "8.22.0"
  },
  "devDependencies": {
    "@testcontainers/postgresql": "12.0.4",
    "@types/node": "26.1.1",
    "@types/pg": "8.20.0",
    "dotenv": "17.4.2",
    "prisma": "7.9.0",
    "tsx": "4.23.1",
    "vitest": "4.1.10"
  },
  "main": "./dist/index.js"
}
