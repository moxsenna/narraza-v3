{
  "name": "@narraza/db",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts"
  },
  "types": "./src/index.ts",
  "scripts": {
    "build": "tsc -b",
    "test": "pnpm run test:integration",
    "test:integration": "vitest run --passWithNoTests",
    "generate": "prisma generate",
    "migrate": "tsx src/migrate.ts",
    "migrate:dev": "prisma migrate dev",
    "migrate:deploy": "prisma migrate deploy",
    "clean": "rimraf dist *.tsbuildinfo"
  },
  "dependencies": {
    "@auth/prisma-adapter": "2.11.3",
    "@narraza/application": "workspace:*",
    "@narraza/core": "workspace:*",
    "@narraza/shared": "workspace:*",
    "@prisma/adapter-pg": "7.9.0",
    "@prisma/client": "7.9.0",
    "pg": "8.22.0"
  },
  "devDependencies": {
    "@testcontainers/postgresql": "12.0.4",
    "@types/node": "26.1.1",
    "@types/pg": "8.20.0",
    "dotenv": "17.4.2",
    "prisma": "7.9.0",
    "tsx": "4.23.1",
    "vitest": "4.1.10"
  }
}
