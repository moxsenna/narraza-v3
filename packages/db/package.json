{
  "name": "@narraza/db",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./auth-adapter": "./src/auth-adapter.ts"
  },
  "types": "./src/index.ts",
  "scripts": {
    "build": "tsc -b",
    "test": "pnpm run test:integration",
    "test:integration": "vitest run --passWithNoTests",
    "generate": "prisma generate --schema ../../prisma/schema.prisma",
    "migrate": "node --import tsx ./src/migrate.ts",
    "migrate:dev": "prisma migrate dev --schema ../../prisma/schema.prisma",
    "clean": "rimraf dist *.tsbuildinfo"
  },
  "dependencies": {
    "@auth/prisma-adapter": "2.11.3",
    "@narraza/application": "workspace:*",
    "@narraza/core": "workspace:*",
    "@narraza/shared": "workspace:*",
    "@prisma/client": "7.9.0"
  },
  "devDependencies": {
    "@types/node": "26.1.1",
    "prisma": "7.9.0",
    "tsx": "4.23.1",
    "vitest": "4.1.10"
  }
}
