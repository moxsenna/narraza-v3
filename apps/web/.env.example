# Web process (schema: packages/shared/src/env/web.ts)
NODE_ENV=development
APP_URL=http://localhost:3000

# ≥32 chars each; peppers MUST differ from AUTH_SECRET (S6.3)
AUTH_SECRET=change-me-to-a-random-32+char-secret
RATE_LIMIT_PEPPER=change-me-to-a-random-32+char-pepper
EMAIL_TOKEN_PEPPER=change-me-to-another-32+char-pepper

DATABASE_URL_WEB=postgresql://narraza:narraza@localhost:5434/narraza

# Email (D10/D21): dev uses Mailpit SMTP; production uses Resend.
EMAIL_FROM=Narraza <no-reply@narraza.local>
SMTP_URL=smtp://localhost:1026
# RESEND_API_KEY=

# D6 display constant (placeholder; calibrated in M7)
MICRO_IDR_PER_CREDIT=10000000

# D21 auth policy — defaults shown; all optional
# PASSWORD_MIN_LENGTH=10
# ARGON2_MEMORY_KIB=19456
# ARGON2_TIME_COST=2
# ARGON2_PARALLELISM=1
# EMAIL_VERIFY_TOKEN_TTL_MINUTES=1440
# PASSWORD_RESET_TOKEN_TTL_MINUTES=30
# EMAIL_TOKEN_RESEND_COOLDOWN_SECONDS=60
# EMAIL_TOKEN_MAX_PER_HOUR_IDENTIFIER=5
# EMAIL_TOKEN_MAX_PER_HOUR_IP=20
# EMAIL_TOKEN_MAX_ACTIVE=3
# LOGIN_MAX_FAILS_PER_HOUR_IDENTIFIER=10
# LOGIN_LOCKOUT_MINUTES=15
# LOGIN_MAX_FAILS_PER_HOUR_IP=30
# REGISTER_MAX_PER_HOUR_IP=10
# SESSION_ABSOLUTE_DAYS=30
# SESSION_IDLE_DAYS=14
# SESSION_ACTIVITY_WRITE_HOURS=6
