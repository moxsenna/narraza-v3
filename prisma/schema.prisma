// Narraza v3 — M0 baseline schema (W0.3, D21).
// Full table set (Lampiran B) arrives in M1 as expand-only migrations.
//
// All timestamps are timestamptz (@db.Timestamptz): the auth raw SQL compares
// column values against now() (which is timestamptz), so storing tz-naive
// timestamps would introduce session-timezone-dependent bugs.

generator client {
  provider     = "prisma-client"
  output       = "../packages/db/src/generated"
  moduleFormat = "esm"
}

datasource db {
  provider = "postgresql"
}

enum UserStatus {
  pending_verification
  active
  suspended
  deleted

  @@map("user_status")
}

enum UiMode {
  pemula
  mahir

  @@map("ui_mode")
}

enum AiTier {
  hemat
  seimbang
  terbaik

  @@map("ai_tier")
}

enum EmailTokenPurpose {
  verify_email
  reset_password

  @@map("email_token_purpose")
}

model User {
  id              String     @id @default(cuid(2))
  email           String     @unique // normalized lowercase
  passwordHash    String     @map("password_hash")
  status          UserStatus @default(pending_verification)
  emailVerifiedAt DateTime?  @map("email_verified_at") @db.Timestamptz(3)
  uiMode          UiMode     @default(pemula) @map("ui_mode")
  tier            AiTier     @default(seimbang)
  createdAt       DateTime   @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt       DateTime   @updatedAt @map("updated_at") @db.Timestamptz(3)

  sessions           Session[]
  emailActionTokens  EmailActionToken[]
  projects           Project[]
  proseWorkingDrafts ProseWorkingDraft[]

  @@map("users")
}

// Field names sessionToken/expires stay Auth.js-adapter-compatible (D8/D21):
// when Google OAuth lands, the Auth.js Prisma adapter reads this same table.
// `expires` = sliding idle expiry (S6.2: idle 14d); absolute cap 30d separate.
model Session {
  id                String    @id @default(cuid(2))
  sessionToken      String    @unique @map("session_token")
  userId            String    @map("user_id")
  expires           DateTime  @map("expires_at") @db.Timestamptz(3)
  absoluteExpiresAt DateTime  @map("absolute_expires_at") @db.Timestamptz(3)
  lastActiveAt      DateTime  @default(now()) @map("last_active_at") @db.Timestamptz(3)
  revokedAt         DateTime? @map("revoked_at") @db.Timestamptz(3)
  createdAt         DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("sessions")
}

// D21: replaces EmailLoginChallenge. One row per issued verify/reset token;
// only the peppered hash is stored. Consume is an atomic conditional UPDATE.
model EmailActionToken {
  id         String            @id @default(cuid(2))
  userId     String            @map("user_id")
  purpose    EmailTokenPurpose
  tokenHash  String            @unique @map("token_hash")
  expiresAt  DateTime          @map("expires_at") @db.Timestamptz(3)
  consumedAt DateTime?         @map("consumed_at") @db.Timestamptz(3)
  revokedAt  DateTime?         @map("revoked_at") @db.Timestamptz(3)
  createdAt  DateTime          @default(now()) @map("created_at") @db.Timestamptz(3)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, purpose])
  @@map("email_action_tokens")
}

// Generic fixed-window counters + lockout markers (D10/D21). Key is a peppered
// HMAC of the identifier/IP — raw identifiers never stored here.
model RateLimitCounter {
  id             String   @id
  kind           String
  keyHash        String   @map("key_hash")
  windowStartsAt DateTime @map("window_starts_at") @db.Timestamptz(3)
  count          Int      @default(0)
  expiresAt      DateTime @map("expires_at") @db.Timestamptz(3)
  updatedAt      DateTime @updatedAt @map("updated_at") @db.Timestamptz(3)

  @@unique([kind, keyHash, windowStartsAt])
  @@index([expiresAt])
  @@map("rate_limit_counters")
}

model AuditEvent {
  id         String   @id @default(cuid(2))
  userId     String?  @map("user_id")
  action     String
  entityType String?  @map("entity_type")
  entityId   String?  @map("entity_id")
  metadata   Json?
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(3)

  @@index([userId, createdAt])
  @@map("audit_events")
}

model Project {
  id                      String    @id
  ownerUserId             String    @map("owner_user_id")
  title                   String
  intakePath              String    @map("intake_path")
  status                  String
  currentCanonicalVersion Int       @default(0) @map("current_canonical_version")
  revision                Int       @default(0)
  deletedAt               DateTime? @map("deleted_at") @db.Timestamptz(3)
  createdAt               DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt               DateTime  @updatedAt @map("updated_at") @db.Timestamptz(3)

  owner                     User                       @relation(fields: [ownerUserId], references: [id], onDelete: Restrict)
  intakeSessions            IntakeSession[]
  conceptSets               ConceptSet[]
  foundations               Foundation[]
  characters                Character[]
  characterStates           CharacterState[]
  characterBeliefs          CharacterBelief[]
  roadmaps                  Roadmap[]
  arcs                      Arc[]
  chapters                  Chapter[]
  beats                     Beat[]
  facts                     Fact[]
  factDisclosures           FactDisclosure[]
  readerFactStates          ReaderFactState[]
  reveals                   Reveal[]
  revealBreadcrumbs         RevealBreadcrumb[]
  proseVersions             ProseVersion[]
  proseWorkingDrafts        ProseWorkingDraft[]
  proseEvidence             ProseEvidence[]
  proposalGroups            ProposalGroup[]
  proposals                 Proposal[]
  generatedCandidates       GeneratedCandidate[]
  canonicalChangeSets       CanonicalChangeSet[]
  canonicalChangeOperations CanonicalChangeOperation[]
  contextSnapshots          ContextSnapshot[]
  generationContextBundles  GenerationContextBundle[]
  aiWorkflowPlans           AiWorkflowPlan[]
  generationJobs            GenerationJob[]
  generationAttempts        GenerationAttempt[]
  workflowInvocations       WorkflowInvocation[]

  @@unique([id, ownerUserId])
  @@index([ownerUserId])
  @@index([status])
  @@map("projects")
}

model IntakeSession {
  id            String   @id
  projectId     String   @map("project_id")
  status        String
  signalCount   Int      @default(0) @map("signal_count")
  schemaVersion Int      @default(1) @map("schema_version")
  payload       Json
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt     DateTime @updatedAt @map("updated_at") @db.Timestamptz(3)

  project  Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  messages IntakeMessage[]

  @@unique([projectId, id])
  @@index([projectId, status])
  @@map("intake_sessions")
}

model IntakeMessage {
  id              String   @id
  projectId       String   @map("project_id")
  intakeSessionId String   @map("intake_session_id")
  role            String
  sequence        Int
  content         String
  jobId           String?  @map("job_id")
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz(3)

  intakeSession IntakeSession  @relation(fields: [projectId, intakeSessionId], references: [projectId, id], onDelete: Cascade)
  job           GenerationJob? @relation(fields: [projectId, jobId], references: [projectId, id], onDelete: NoAction, map: "intake_messages_job_fkey")

  @@unique([projectId, id])
  @@unique([intakeSessionId, sequence])
  @@index([projectId, intakeSessionId, sequence])
  @@map("intake_messages")
}

model ConceptSet {
  id             String   @id
  projectId      String   @map("project_id")
  sourceJobId    String?  @map("source_job_id")
  status         String
  dependencyHash String   @map("dependency_hash")
  schemaVersion  Int      @default(1) @map("schema_version")
  payload        Json
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt      DateTime @updatedAt @map("updated_at") @db.Timestamptz(3)

  project   Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  sourceJob GenerationJob? @relation(fields: [projectId, sourceJobId], references: [projectId, id], onDelete: NoAction, map: "concept_sets_source_job_fkey")
  concepts  Concept[]

  @@unique([projectId, id])
  @@index([projectId, createdAt])
  @@map("concept_sets")
}

model Concept {
  id            String   @id
  projectId     String   @map("project_id")
  conceptSetId  String   @map("concept_set_id")
  ordinal       Int
  title         String
  synopsis      String
  schemaVersion Int      @default(1) @map("schema_version")
  payload       Json
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt     DateTime @updatedAt @map("updated_at") @db.Timestamptz(3)

  conceptSet ConceptSet @relation(fields: [projectId, conceptSetId], references: [projectId, id], onDelete: Cascade)

  @@unique([projectId, id])
  @@unique([conceptSetId, ordinal])
  @@index([projectId, conceptSetId, ordinal])
  @@map("concepts")
}

model Foundation {
  id            String    @id
  projectId     String    @unique @map("project_id")
  status        String
  revision      Int       @default(0)
  confirmedAt   DateTime? @map("confirmed_at") @db.Timestamptz(3)
  lockedAt      DateTime? @map("locked_at") @db.Timestamptz(3)
  schemaVersion Int       @default(1) @map("schema_version")
  payload       Json
  createdAt     DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt     DateTime  @updatedAt @map("updated_at") @db.Timestamptz(3)

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, id])
  @@map("foundations")
}

model Character {
  id            String    @id
  projectId     String    @map("project_id")
  displayName   String    @map("display_name")
  role          String
  revision      Int       @default(0)
  schemaVersion Int       @default(1) @map("schema_version")
  payload       Json
  deletedAt     DateTime? @map("deleted_at") @db.Timestamptz(3)
  createdAt     DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt     DateTime  @updatedAt @map("updated_at") @db.Timestamptz(3)

  project Project           @relation(fields: [projectId], references: [id], onDelete: Cascade)
  states  CharacterState[]
  beliefs CharacterBelief[]

  @@unique([projectId, id])
  @@map("characters")
}

model CharacterState {
  id                String   @id
  projectId         String   @map("project_id")
  characterId       String   @map("character_id")
  effectiveSequence Int      @map("effective_sequence")
  proseVersionId    String?  @map("prose_version_id")
  schemaVersion     Int      @default(1) @map("schema_version")
  payload           Json
  createdAt         DateTime @default(now()) @map("created_at") @db.Timestamptz(3)

  project      Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  character    Character     @relation(fields: [projectId, characterId], references: [projectId, id], onDelete: Cascade)
  proseVersion ProseVersion? @relation(fields: [projectId, proseVersionId], references: [projectId, id], onDelete: NoAction)

  @@unique([projectId, id])
  @@index([projectId, characterId, effectiveSequence(sort: Desc), createdAt(sort: Desc), id(sort: Desc)], map: "character_states_fold_idx")
  @@map("character_states")
}

model CharacterBelief {
  id                String   @id
  projectId         String   @map("project_id")
  characterId       String   @map("character_id")
  beliefKey         String   @map("belief_key")
  effectiveSequence Int      @map("effective_sequence")
  reasonCode        String?  @map("reason_code")
  schemaVersion     Int      @default(1) @map("schema_version")
  payload           Json
  createdAt         DateTime @default(now()) @map("created_at") @db.Timestamptz(3)

  project   Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  character Character @relation(fields: [projectId, characterId], references: [projectId, id], onDelete: Cascade)

  @@unique([projectId, id])
  @@index([projectId, characterId, beliefKey, effectiveSequence(sort: Desc), createdAt(sort: Desc), id(sort: Desc)], map: "character_beliefs_fold_idx")
  @@map("character_beliefs")
}

model Roadmap {
  id            String    @id
  projectId     String    @map("project_id")
  title         String
  revision      Int       @default(0)
  schemaVersion Int       @default(1) @map("schema_version")
  payload       Json
  deletedAt     DateTime? @map("deleted_at") @db.Timestamptz(3)
  createdAt     DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt     DateTime  @updatedAt @map("updated_at") @db.Timestamptz(3)

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  arcs    Arc[]

  @@unique([projectId, id])
  @@map("roadmaps")
}

model Arc {
  id            String    @id
  projectId     String    @map("project_id")
  roadmapId     String    @map("roadmap_id")
  ordinal       Int
  title         String
  revision      Int       @default(0)
  schemaVersion Int       @default(1) @map("schema_version")
  payload       Json
  deletedAt     DateTime? @map("deleted_at") @db.Timestamptz(3)
  createdAt     DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt     DateTime  @updatedAt @map("updated_at") @db.Timestamptz(3)

  project  Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  roadmap  Roadmap   @relation(fields: [projectId, roadmapId], references: [projectId, id], onDelete: Cascade)
  chapters Chapter[]

  @@unique([projectId, id])
  @@index([projectId, roadmapId])
  @@map("arcs")
}

model Chapter {
  id                String    @id
  projectId         String    @map("project_id")
  arcId             String    @map("arc_id")
  ordinal           Int
  title             String
  narrativeSequence Int       @map("narrative_sequence")
  revision          Int       @default(0)
  schemaVersion     Int       @default(1) @map("schema_version")
  payload           Json
  deletedAt         DateTime? @map("deleted_at") @db.Timestamptz(3)
  createdAt         DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt         DateTime  @updatedAt @map("updated_at") @db.Timestamptz(3)

  project           Project            @relation(fields: [projectId], references: [id], onDelete: Cascade)
  arc               Arc                @relation(fields: [projectId, arcId], references: [projectId, id], onDelete: Cascade)
  beats             Beat[]
  reveals           Reveal[]
  revealBreadcrumbs RevealBreadcrumb[]

  @@unique([projectId, id])
  @@index([projectId, arcId])
  @@index([projectId, narrativeSequence])
  @@map("chapters")
}

model Beat {
  id                     String    @id
  projectId              String    @map("project_id")
  chapterId              String    @map("chapter_id")
  ordinal                Int
  narrativeSequence      Int       @map("narrative_sequence")
  acceptedProseVersionId String?   @map("accepted_prose_version_id")
  revision               Int       @default(0)
  schemaVersion          Int       @default(1) @map("schema_version")
  payload                Json
  deletedAt              DateTime? @map("deleted_at") @db.Timestamptz(3)
  createdAt              DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt              DateTime  @updatedAt @map("updated_at") @db.Timestamptz(3)

  project              Project             @relation(fields: [projectId], references: [id], onDelete: Cascade)
  chapter              Chapter             @relation(fields: [projectId, chapterId], references: [projectId, id], onDelete: Cascade)
  acceptedProseVersion ProseVersion?       @relation("AcceptedProse", fields: [projectId, id, acceptedProseVersionId], references: [projectId, beatId, id], onDelete: NoAction, map: "beats_accepted_prose_belongs_to_beat_fkey")
  proseVersions        ProseVersion[]      @relation("BeatProseVersions")
  proseWorkingDrafts   ProseWorkingDraft[]
  reveals              Reveal[]
  revealBreadcrumbs    RevealBreadcrumb[]

  @@unique([projectId, id])
  @@unique([projectId, chapterId, id])
  @@unique([projectId, id, acceptedProseVersionId])
  @@index([projectId, chapterId])
  @@index([projectId, narrativeSequence])
  @@map("beats")
}

model Fact {
  id            String    @id
  projectId     String    @map("project_id")
  factKey       String    @map("fact_key")
  canonStatus   String    @map("canon_status")
  visibility    String
  revision      Int       @default(0)
  schemaVersion Int       @default(1) @map("schema_version")
  payload       Json
  deletedAt     DateTime? @map("deleted_at") @db.Timestamptz(3)
  createdAt     DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt     DateTime  @updatedAt @map("updated_at") @db.Timestamptz(3)

  project          Project           @relation(fields: [projectId], references: [id], onDelete: Cascade)
  disclosures      FactDisclosure[]
  readerFactStates ReaderFactState[]
  reveals          Reveal[]

  @@unique([projectId, id])
  @@index([projectId, canonStatus])
  @@map("facts")
}

model FactDisclosure {
  id                   String   @id
  projectId            String   @map("project_id")
  factId               String   @map("fact_id")
  proseVersionId       String?  @map("prose_version_id")
  eventType            String   @map("event_type")
  effectiveSequence    Int      @map("effective_sequence")
  retractsDisclosureId String?  @map("retracts_disclosure_id")
  evidenceId           String?  @map("evidence_id")
  createdAt            DateTime @default(now()) @map("created_at") @db.Timestamptz(3)

  project                Project           @relation(fields: [projectId], references: [id], onDelete: Cascade)
  fact                   Fact              @relation(fields: [projectId, factId], references: [projectId, id], onDelete: Cascade)
  proseVersion           ProseVersion?     @relation(fields: [projectId, proseVersionId], references: [projectId, id], onDelete: NoAction)
  retractsDisclosure     FactDisclosure?   @relation("DisclosureRetraction", fields: [projectId, factId, retractsDisclosureId], references: [projectId, factId, id], onDelete: Restrict, map: "fact_disclosures_retraction_fact_fkey")
  retractedBy            FactDisclosure[]  @relation("DisclosureRetraction")
  evidence               ProseEvidence?    @relation(fields: [projectId, proseVersionId, evidenceId], references: [projectId, proseVersionId, id], onDelete: NoAction, map: "fact_disclosures_evidence_prose_fkey")
  readerFactStateSources ReaderFactState[]

  @@unique([projectId, id])
  @@unique([projectId, factId, id])
  @@index([projectId, factId, effectiveSequence(sort: Desc), createdAt(sort: Desc), id(sort: Desc)], map: "fact_disclosures_fold_idx")
  @@map("fact_disclosures")
}

model ReaderFactState {
  id                 String   @id
  projectId          String   @map("project_id")
  factId             String   @map("fact_id")
  asOfSequence       Int      @map("as_of_sequence")
  state              String
  sourceDisclosureId String   @map("source_disclosure_id")
  createdAt          DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt          DateTime @updatedAt @map("updated_at") @db.Timestamptz(3)

  project          Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  fact             Fact           @relation(fields: [projectId, factId], references: [projectId, id], onDelete: Cascade)
  sourceDisclosure FactDisclosure @relation(fields: [projectId, factId, sourceDisclosureId], references: [projectId, factId, id], onDelete: Restrict, map: "reader_fact_states_source_fact_fkey")

  @@unique([projectId, id])
  @@unique([projectId, factId])
  @@map("reader_fact_states")
}

model Reveal {
  id             String   @id
  projectId      String   @map("project_id")
  factId         String   @map("fact_id")
  chapterId      String   @map("chapter_id")
  beatId         String?  @map("beat_id")
  targetSequence Int      @map("target_sequence")
  revision       Int      @default(0)
  schemaVersion  Int      @default(1) @map("schema_version")
  payload        Json
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt      DateTime @updatedAt @map("updated_at") @db.Timestamptz(3)

  project     Project            @relation(fields: [projectId], references: [id], onDelete: Cascade)
  fact        Fact               @relation(fields: [projectId, factId], references: [projectId, id], onDelete: Cascade)
  chapter     Chapter            @relation(fields: [projectId, chapterId], references: [projectId, id], onDelete: Cascade)
  beat        Beat?              @relation(fields: [projectId, chapterId, beatId], references: [projectId, chapterId, id], onDelete: NoAction, map: "reveals_beat_chapter_fkey")
  breadcrumbs RevealBreadcrumb[]

  @@unique([projectId, id])
  @@index([projectId, targetSequence])
  @@map("reveals")
}

model RevealBreadcrumb {
  id            String   @id
  projectId     String   @map("project_id")
  revealId      String   @map("reveal_id")
  chapterId     String   @map("chapter_id")
  beatId        String?  @map("beat_id")
  sequence      Int
  schemaVersion Int      @default(1) @map("schema_version")
  payload       Json
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt     DateTime @updatedAt @map("updated_at") @db.Timestamptz(3)

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  reveal  Reveal  @relation(fields: [projectId, revealId], references: [projectId, id], onDelete: Cascade)
  chapter Chapter @relation(fields: [projectId, chapterId], references: [projectId, id], onDelete: Cascade)
  beat    Beat?   @relation(fields: [projectId, chapterId, beatId], references: [projectId, chapterId, id], onDelete: NoAction, map: "reveal_breadcrumbs_beat_chapter_fkey")

  @@unique([projectId, id])
  @@unique([revealId, sequence])
  @@index([projectId, revealId, sequence])
  @@map("reveal_breadcrumbs")
}

model ProseVersion {
  id                String   @id
  projectId         String   @map("project_id")
  beatId            String   @map("beat_id")
  sourceCandidateId String?  @map("source_candidate_id")
  status            String
  revision          Int      @default(0)
  content           String
  contentHash       String   @map("content_hash")
  createdAt         DateTime @default(now()) @map("created_at") @db.Timestamptz(3)

  project         Project             @relation(fields: [projectId], references: [id], onDelete: Cascade)
  beat            Beat                @relation("BeatProseVersions", fields: [projectId, beatId], references: [projectId, id], onDelete: Cascade)
  acceptedByBeat  Beat?               @relation("AcceptedProse")
  disclosures     FactDisclosure[]
  evidence        ProseEvidence[]
  characterStates CharacterState[]
  sourceCandidate        GeneratedCandidate?  @relation("SourceCandidate", fields: [projectId, sourceCandidateId], references: [projectId, id], onDelete: NoAction)
  backpointingCandidates GeneratedCandidate[] @relation("CandidateProseBackpointer")

  @@unique([projectId, id])
  @@unique([projectId, beatId, id])
  @@unique([projectId, sourceCandidateId, id])
  @@index([projectId, beatId, createdAt])
  @@map("prose_versions")
}

model ProseWorkingDraft {
  id          String    @id
  projectId   String    @map("project_id")
  beatId      String    @map("beat_id")
  userId      String    @map("user_id")
  revision    Int       @default(0)
  content     String
  contentHash String    @map("content_hash")
  deletedAt   DateTime? @map("deleted_at") @db.Timestamptz(3)
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt   DateTime  @updatedAt @map("updated_at") @db.Timestamptz(3)

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  beat    Beat    @relation(fields: [projectId, beatId], references: [projectId, id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Restrict)

  @@unique([projectId, id])
  @@index([userId])
  @@map("prose_working_drafts")
}

model ProseEvidence {
  id             String   @id
  projectId      String   @map("project_id")
  proseVersionId String   @map("prose_version_id")
  startUtf16     Int      @map("start_utf16")
  endUtf16       Int      @map("end_utf16")
  contentHash    String   @map("content_hash")
  evidenceType   String   @map("evidence_type")
  schemaVersion  Int      @default(1) @map("schema_version")
  payload        Json
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(3)

  project      Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  proseVersion ProseVersion     @relation(fields: [projectId, proseVersionId], references: [projectId, id], onDelete: Cascade)
  disclosures  FactDisclosure[]

  @@unique([projectId, id])
  @@unique([projectId, proseVersionId, id])
  @@index([projectId, proseVersionId, startUtf16, endUtf16], map: "prose_evidence_project_id_prose_version_id_start_utf16_end_utf1")
  @@map("prose_evidence")
}

model ProposalGroup {
  id             String   @id
  projectId      String   @map("project_id")
  kind           String
  status         String
  dependencyHash String   @map("dependency_hash")
  sourceJobId    String?  @map("source_job_id")
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt      DateTime @updatedAt @map("updated_at") @db.Timestamptz(3)

  project             Project              @relation(fields: [projectId], references: [id], onDelete: Cascade)
  sourceJob           GenerationJob?       @relation("ProposalGroupSourceJob", fields: [projectId, sourceJobId], references: [projectId, id], onDelete: NoAction)
  proposals           Proposal[]
  generatedCandidates GeneratedCandidate[]

  @@unique([projectId, id])
  @@index([projectId, status])
  @@map("proposal_groups")
}

model Proposal {
  id                        String   @id
  projectId                 String   @map("project_id")
  groupId                   String   @map("group_id")
  changeSetId               String   @map("change_set_id")
  source                    String
  status                    String
  operationsHash            String   @map("operations_hash")
  dependencyHash            String   @map("dependency_hash")
  revalidatedFromProposalId String?  @map("revalidated_from_proposal_id")
  validationReportId        String?  @map("validation_report_id")
  createdAt                 DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt                 DateTime @updatedAt @map("updated_at") @db.Timestamptz(3)

  project                 Project            @relation(fields: [projectId], references: [id], onDelete: Cascade)
  group                   ProposalGroup      @relation(fields: [projectId, groupId], references: [projectId, id], onDelete: Cascade)
  changeSet               CanonicalChangeSet @relation(fields: [projectId, changeSetId], references: [projectId, id], onDelete: Cascade)
  revalidatedFromProposal Proposal?          @relation("ProposalRevalidation", fields: [projectId, revalidatedFromProposalId], references: [projectId, id], onDelete: NoAction)
  revalidatedProposals    Proposal[]         @relation("ProposalRevalidation")

  @@unique([projectId, id])
  @@index([projectId, groupId, status])
  @@index([projectId, status])
  @@map("proposals")
}

model GeneratedCandidate {
  id             String   @id
  projectId      String   @map("project_id")
  groupId        String   @map("group_id")
  jobId          String?  @map("job_id")
  ordinal        Int
  proseVersionId String?  @map("prose_version_id")
  schemaVersion  Int      @default(1) @map("schema_version")
  payload        Json
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(3)

  project             Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  group               ProposalGroup  @relation(fields: [projectId, groupId], references: [projectId, id], onDelete: Cascade)
  job                 GenerationJob? @relation(fields: [projectId, jobId], references: [projectId, id], onDelete: NoAction)
  proseVersion        ProseVersion?  @relation("CandidateProseBackpointer", fields: [projectId, id, proseVersionId], references: [projectId, sourceCandidateId, id], onDelete: NoAction, map: "generated_candidates_prose_backpointer_fkey")
  sourceProseVersions ProseVersion[] @relation("SourceCandidate")

  @@unique([projectId, id])
  @@unique([groupId, ordinal])
  @@index([projectId, groupId])
  @@map("generated_candidates")
}

model CanonicalChangeSet {
  id                      String   @id
  projectId               String   @map("project_id")
  origin                  String
  status                  String
  baseCanonicalVersion    Int      @map("base_canonical_version")
  operationsHash          String   @map("operations_hash")
  appliedCanonicalVersion Int?     @map("applied_canonical_version")
  createdAt               DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt               DateTime @updatedAt @map("updated_at") @db.Timestamptz(3)

  project    Project                    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  proposals  Proposal[]
  operations CanonicalChangeOperation[]

  @@unique([projectId, id])
  @@index([projectId, status])
  @@map("canonical_change_sets")
}

model CanonicalChangeOperation {
  id               String   @id
  projectId        String   @map("project_id")
  changeSetId      String   @map("change_set_id")
  ordinal          Int
  operationType    String   @map("operation_type")
  targetEntityType String   @map("target_entity_type")
  targetEntityId   String   @map("target_entity_id")
  expectedRevision Int?     @map("expected_revision")
  risk             String
  schemaVersion    Int      @default(1) @map("schema_version")
  payload          Json
  createdAt        DateTime @default(now()) @map("created_at") @db.Timestamptz(3)

  project   Project            @relation(fields: [projectId], references: [id], onDelete: Cascade)
  changeSet CanonicalChangeSet @relation(fields: [projectId, changeSetId], references: [projectId, id], onDelete: Cascade)

  @@unique([projectId, id])
  @@unique([changeSetId, ordinal])
  @@index([projectId, targetEntityType, targetEntityId])
  @@map("canonical_change_operations")
}

model ContextSnapshot {
  id             String   @id
  projectId      String   @map("project_id")
  packetKind     String   @map("packet_kind")
  dataClass      String   @map("data_class")
  dependencyHash String   @map("dependency_hash")
  contentHash    String   @map("content_hash")
  schemaVersion  Int      @default(1) @map("schema_version")
  payload        Json
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(3)

  project Project                   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  bundles GenerationContextBundle[]

  @@unique([projectId, id])
  @@index([projectId, dependencyHash])
  @@map("context_snapshots")
}

model GenerationContextBundle {
  id             String    @id
  projectId      String    @map("project_id")
  snapshotId     String    @map("snapshot_id")
  dependencyHash String    @map("dependency_hash")
  bundleHash     String    @map("bundle_hash")
  expiresAt      DateTime  @map("expires_at") @db.Timestamptz(3)
  consumedAt     DateTime? @map("consumed_at") @db.Timestamptz(3)
  schemaVersion  Int       @default(1) @map("schema_version")
  payload        Json
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)

  project       Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  snapshot      ContextSnapshot  @relation(fields: [projectId, snapshotId], references: [projectId, id], onDelete: Cascade)
  workflowPlans AiWorkflowPlan[]
  jobs          GenerationJob[]

  @@unique([projectId, id])
  @@unique([projectId, bundleHash])
  @@map("generation_context_bundles")
}

model AiWorkflowPlan {
  id                   String   @id
  projectId            String   @map("project_id")
  bundleId             String   @map("bundle_id")
  workflowKind         String   @map("workflow_kind")
  planHash             String   @map("plan_hash")
  estimatedMaxMicroIdr BigInt   @map("estimated_max_micro_idr")
  schemaVersion        Int      @default(1) @map("schema_version")
  payload              Json
  createdAt            DateTime @default(now()) @map("created_at") @db.Timestamptz(3)

  project Project                 @relation(fields: [projectId], references: [id], onDelete: Cascade)
  bundle  GenerationContextBundle @relation(fields: [projectId, bundleId], references: [projectId, id], onDelete: Cascade)
  jobs    GenerationJob[]

  @@unique([projectId, id])
  @@unique([projectId, bundleId, id])
  @@unique([projectId, planHash])
  @@map("ai_workflow_plans")
}

model ModelPriceSnapshot {
  id                 String   @id
  providerId         String   @map("provider_id")
  requestedModelId   String   @map("requested_model_id")
  resolvedModelId    String   @map("resolved_model_id")
  inputRateMicroIdr  BigInt   @map("input_rate_micro_idr")
  outputRateMicroIdr BigInt   @map("output_rate_micro_idr")
  currency           String
  effectiveAt        DateTime @map("effective_at") @db.Timestamptz(3)
  schemaVersion      Int      @default(1) @map("schema_version")
  payload            Json
  createdAt          DateTime @default(now()) @map("created_at") @db.Timestamptz(3)

  usageEvents AiUsageEvent[]

  @@unique([providerId, resolvedModelId, effectiveAt])
  @@map("model_price_snapshots")
}

model AiUsageEvent {
  id                   String   @id
  projectId            String?  @map("project_id")
  jobId                String?  @map("job_id")
  attemptId            String?  @map("attempt_id")
  priceSnapshotId      String   @map("price_snapshot_id")
  inputTokens          Int      @map("input_tokens")
  outputTokens         Int      @map("output_tokens")
  providerCostMicroIdr BigInt   @map("provider_cost_micro_idr")
  chargedParty         String   @map("charged_party")
  dedupeKey            String   @unique @map("dedupe_key")
  createdAt            DateTime @default(now()) @map("created_at") @db.Timestamptz(3)

  priceSnapshot ModelPriceSnapshot @relation(fields: [priceSnapshotId], references: [id], onDelete: Restrict)

  @@index([projectId, createdAt])
  @@index([jobId])
  @@index([attemptId])
  @@map("ai_usage_events")
}

model GenerationJob {
  id                String    @id
  projectId         String    @map("project_id")
  kind              String
  status            String
  priority          Int       @default(0)
  availableAt       DateTime  @map("available_at") @db.Timestamptz(3)
  leaseToken        String?   @map("lease_token")
  leaseExpiresAt    DateTime? @map("lease_expires_at") @db.Timestamptz(3)
  fenceVersion      Int       @default(0) @map("fence_version")
  cancelRequestedAt DateTime? @map("cancel_requested_at") @db.Timestamptz(3)
  retryOfJobId      String?   @map("retry_of_job_id")
  bundleId          String?   @map("bundle_id")
  workflowPlanId    String?   @map("workflow_plan_id")
  reservationId     String?   @map("reservation_id")
  schemaVersion     Int       @default(1) @map("schema_version")
  payload           Json
  createdAt         DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt         DateTime  @updatedAt @map("updated_at") @db.Timestamptz(3)

  project             Project                  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  retryOfJob          GenerationJob?           @relation("JobRetry", fields: [projectId, retryOfJobId], references: [projectId, id], onDelete: NoAction)
  retries             GenerationJob[]          @relation("JobRetry")
  bundle              GenerationContextBundle? @relation(fields: [projectId, bundleId], references: [projectId, id], onDelete: NoAction)
  workflowPlan        AiWorkflowPlan?          @relation(fields: [projectId, bundleId, workflowPlanId], references: [projectId, bundleId, id], onDelete: NoAction)
  attempts            GenerationAttempt[]
  invocations         WorkflowInvocation[]
  proposalGroups      ProposalGroup[]          @relation("ProposalGroupSourceJob")
  generatedCandidates GeneratedCandidate[]
  intakeMessages      IntakeMessage[]
  conceptSets         ConceptSet[]

  @@unique([projectId, id])
  @@map("generation_jobs")
}

model GenerationAttempt {
  id                String    @id
  projectId         String    @map("project_id")
  jobId             String    @map("job_id")
  invocationId      String    @map("invocation_id")
  ordinal           Int
  status            String
  providerRequestId String?   @map("provider_request_id")
  resultHash        String?   @map("result_hash")
  startedAt         DateTime  @map("started_at") @db.Timestamptz(3)
  finishedAt        DateTime? @map("finished_at") @db.Timestamptz(3)
  schemaVersion     Int       @default(1) @map("schema_version")
  payload           Json
  createdAt         DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt         DateTime  @updatedAt @map("updated_at") @db.Timestamptz(3)

  project        Project              @relation(fields: [projectId], references: [id], onDelete: Cascade)
  job            GenerationJob        @relation(fields: [projectId, jobId], references: [projectId, id], onDelete: Cascade)
  invocation     WorkflowInvocation   @relation("InvocationAttempts", fields: [projectId, jobId, invocationId], references: [projectId, jobId, id], onDelete: Cascade)
  wonInvocations WorkflowInvocation[] @relation("InvocationWinner")

  @@unique([projectId, id])
  @@unique([projectId, jobId, id])
  @@unique([projectId, jobId, invocationId, id])
  @@unique([invocationId, ordinal])
  @@map("generation_attempts")
}

model WorkflowInvocation {
  id              String   @id
  projectId       String   @map("project_id")
  jobId           String   @map("job_id")
  stageKey        String   @map("stage_key")
  status          String
  winnerAttemptId String?  @map("winner_attempt_id")
  fenceVersion    Int      @default(0) @map("fence_version")
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt       DateTime @updatedAt @map("updated_at") @db.Timestamptz(3)

  project       Project             @relation(fields: [projectId], references: [id], onDelete: Cascade)
  job           GenerationJob       @relation(fields: [projectId, jobId], references: [projectId, id], onDelete: Cascade)
  attempts      GenerationAttempt[] @relation("InvocationAttempts")
  winnerAttempt GenerationAttempt?  @relation("InvocationWinner", fields: [projectId, jobId, id, winnerAttemptId], references: [projectId, jobId, invocationId, id], onDelete: NoAction, map: "workflow_invocations_winner_attempt_fkey")

  @@unique([projectId, id])
  @@unique([projectId, jobId, id])
  @@unique([jobId, stageKey])
  @@map("workflow_invocations")
}
